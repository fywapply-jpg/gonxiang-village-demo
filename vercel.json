{
  "framework": null,
  "installCommand": "echo skip-install",
  "buildCommand": "echo skip-build",
  "outputDirectory": "v2demo",
  "redirects": [
    { "source": "/", "destination": "/demo.html", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
